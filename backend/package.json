{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "seed:players": "tsx scripts/seed-players.ts",
    "seed:players:fifa": "tsx scripts/seed-players.ts --csv data/datasets/players/fifa_players.csv --mapping data/datasets/mappings/fifa_players.mapping.json --dataset fifa-player-dataset",
    "seed:players:fut": "tsx scripts/seed-players.ts --csv data/datasets/players/fut/FIFA_23_Fut_Players.csv --mapping data/datasets/mappings/fifa_players.mapping.json --dataset fifa-fut-player-dataset",
    "seed:players:public": "tsx scripts/seed-players-from-public.ts --publicDir data/datasets/players",
    "seed:players:public:all": "tsx scripts/seed-players-from-public.ts --publicDir data/datasets/players --all-seasons",
    "seed:players:merged": "tsx scripts/seed-players-merged.ts --publicDir data/datasets/players/public --futCsv data/datasets/players/fut/FIFA_23_Fut_Players.csv --mapping data/datasets/mappings/fifa_players.mapping.json --dataset fifa-merged-profile-fut",
    "seed:events": "tsx scripts/seed-events-calibration.ts --mapping data/datasets/mappings/football_events.mapping.json --dataset football-events-kaggle --profileKey default-match-calibration-v1",
    "test": "tsx --test src/services/__tests__/*.test.ts",
    "test:simulation": "tsx --test src/services/__tests__/simulation.engine.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
